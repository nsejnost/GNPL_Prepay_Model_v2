entrypoint = "main.py"
modules = ["python-3.11"]

# The Run button prints a help banner because there isn't a single
# canonical entry point — the pipeline has four stages. To wire Run to
# a specific stage, replace the `run` line with one of the commands
# listed in the banner.
run = "printf 'GNPL Prepay Model\\n\\nrun one of:\\n  python3 main.py --skip-download   # rebuild parquet from gnma_mf_data/\\n  python3 model/train_model.py        # re-fit the logistic regression\\n  python3 model/predict_python.py     # score sample_loans.csv\\n  python3 webapp/build_data.py        # refresh the JSX explorer\\n  python3 model/build_excel.py        # rebuild GNPL_Prepay_Model.xlsx\\n'"

[nix]
channel = "stable-23_11"

[unitTest]
language = "python3"

[packager]
language = "python3"

[packager.features]
packageSearch = true
guessImports = true
